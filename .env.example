# Salesforce OAuth (Web Server flow)
SF_CLIENT_ID=your_connected_app_consumer_key
SF_CLIENT_SECRET=your_connected_app_consumer_secret
SF_CALLBACK_URL=http://localhost:8080/auth/callback   # change to your production URL when deployed
SF_INSTANCE_URL=https://login.salesforce.com          # or https://test.salesforce.com for sandbox

# Session (generate a random string, e.g.: openssl rand -hex 32)
SESSION_SECRET=replace_with_a_long_random_string

# Supabase / Postgres
DATABASE_URL=postgresql://postgres:password@db.yourproject.supabase.co:5432/postgres

# Optional
PORT=8080
